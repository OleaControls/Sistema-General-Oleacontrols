
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          String   @id @default(cuid())
  employeeId  String   @unique // Número de empleado
  name        String   // Nombre completo
  roles       String[] @default(["COLLABORATOR"])
  email       String   @unique
  avatar      String?
  status      String   @default("ACTIVE")
  
  // 1. Datos personales básicos
  birthDate       DateTime?
  birthPlace      String?
  nationality     String?
  maritalStatus   String?
  address         String?
  phone           String?
  emergencyContactName  String?
  emergencyContactPhone String?

  // 2. Documentos oficiales (ID/Strings y Referencias PDF)
  ine             String?
  curp            String?
  rfc             String?
  nss             String?
  birthCertificate String? 
  proofOfResidency String?
  cv               String?
  ineDoc           String?

  // 3. Contratación
  contractSigned       String?
  privacyPolicySigned  String?
  internalRulesSigned  String?
  imssHigh            String?

  // 4. Seguimiento Laboral
  studyCertificate       String?
  degreeOrProfessionalId String?
  diplomasOrCourses      String?
  laborCertifications    String?
  recommendationLetter   String?
  performanceEvaluations String?
  receivedTraining       String?
  administrativeActs     String?
  disciplinaryReports    String?
  permitsOrLicenses      String?

  // 5. Baja del Empleado
  resignationLetter       String?
  settlementOrLiquidation String?
  imssLow                String?
  laborConstancy         String?

  // 6. Datos laborales (Actuales)
  position        String?
  department      String?
  joinDate        DateTime @default(now())
  contractType    String?  // temporal, indefinido, etc.
  workSchedule    String?  // Horario
  salary          Float?   // Salario acordado

  // 4. Datos para nómina
  bankName        String?
  bankAccount     String?  // Cuenta o CLABE
  paymentType     String?  // semanal, quincenal, mensual

  reportsTo       String?
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  credentials     Credentials?

  // Vacaciones
  vacationBalance      Float    @default(0)
  vacationLastRenewal  DateTime @default(now())
  vacationRequests     VacationRequest[]

  // Relaciones Operativas

  techOTs         WorkOrder[] @relation("TechOTs")
  supervisorOTs   WorkOrder[] @relation("SupervisorOTs")
  createdOTs      WorkOrder[] @relation("CreatedOTs")
  assignedOTs     WorkOrder[] @relation("AssignedOTs")
  expenses        Expense[]

  // --- RELACIONES CRM OPUESTAS ---
  assignedLeads     Lead[]           // Leads asignados a este empleado
  assignedDeals     Deal[]           @relation("DealAssignee")
  quotesCreated     Quote[]          @relation("QuoteCreator")
  quotesSold        Quote[]          @relation("QuoteSeller")
  ownedClients      Client[]         @relation("ClientOwner")

  // --- GESTIÓN DE DATOS DE VENTAS ---
  salesBitacora     SalesBitacora[]  @relation("SellerBitacora")
  salesReports      SalesDailyReport[] @relation("SellerReports")
  salesPortfolio    SalesPortfolio[] @relation("SellerPortfolio")

  // --- RELACIONES LMS ---
  lmsEnrollments    LMSEnrollment[]  @relation("LMSEnrollments")
  lmsCertificates   LMSCertificate[] @relation("LMSCertificates")
  lmsCoursesCreated LMSCourse[]      @relation("LMSCourseCreator")

  // --- EVALUACIONES ---
  evaluationsReceived Evaluation[] @relation("EvaluationTarget")
  evaluationsGiven    Evaluation[] @relation("EvaluationEvaluator")

  // --- ACTIVOS Y EPP ---
  assets          Asset[]      @relation("EmployeeAssets")
}

model Credentials {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  roles      String[]
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model WorkOrder {
  id                String   @id @default(cuid())
  otNumber          String   @unique // Folio: OT-2026-001 o OT-ST01-A
  title             String
  description       String?  // Equivalent to workDescription
  status            String   @default("PENDING") // UNASSIGNED, ASSIGNED, ACCEPTED, IN_PROGRESS, COMPLETED, VALIDATED
  priority          String   @default("MEDIUM")  // LOW, MEDIUM, HIGH, URGENT
  
  // Ubicación y Establecimiento
  storeNumber       String?
  storeName         String?
  clientName        String   // mapped to 'client' in frontend
  clientEmail       String?
  clientPhone       String?
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  address           String
  secondaryAddress  String?
  otAddress         String?
  otReference       String?
  latitude          Float?
  longitude         Float?   // Changed to Float to match Leaflet mapping
  
  // Fechas y Tiempos
  scheduledDate     DateTime?
  arrivalTime       String?   // "09:00"
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Personal Relacionado
  technicianId      String?   // leadTechId
  technician        Employee? @relation("TechOTs", fields: [technicianId], references: [id])
  assistantTechs    Json?     // Almacena array de IDs o nombres de apoyo
  supportTechs      Json?
  
  supervisorId      String
  supervisor        Employee  @relation("SupervisorOTs", fields: [supervisorId], references: [id])

  creatorId         String?
  creator           Employee? @relation("CreatedOTs", fields: [creatorId], references: [id])

  assignedById      String?
  assignedBy        Employee? @relation("AssignedOTs", fields: [assignedById], references: [id])

  // Resultados, Financiero y Cierre
  assignedFunds     Float     @default(0)
  systemType        String?   // SDI, SCA, CCTV, SSA, RMC, MDE
  deliveryDetails   String?   // "Por este conducto se hace la entrega..."
  report            String?   // Resumen técnico
  pendingTasks      Json?     // Lista de observaciones/pendientes [{id, desc}]
  jornadas          Json?     // Historial de jornadas [{id, startedAt, endedAt, techId, status, pauseReason}]
  signature         String?   // Firma Técnico (Base64)
  clientSignature   String?   // Firma Cliente (Base64)
  clientSignature2  String?   // Firma Cliente 2 (Opcional)
  clientContact2    Json?     // {name, email}
  isLocked          Boolean   @default(false)
  deliveryActUrl    String?   // URL del PDF en R2
  
  evidences         Evidence[]
  expenses          Expense[]
  
  // --- RELACIÓN OPUESTA EVALUATION ---
  evaluations       Evaluation[]
}

model Evidence {
  id          String    @id @default(cuid())
  url         String    // Base64 o URL del archivo
  type        String    @default("IMAGE") // IMAGE, PDF
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  createdAt   DateTime  @default(now())
}

model Expense {
  id          String    @id @default(cuid())
  amount      Float
  category    String
  description String?
  paymentMethod String    @default("CASH") // CASH, COMPANY_CARD, PERSONAL_CARD
  receipt     String?   // PDF/Imagen Base64
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  comment     String?   // Motivo de aprobación o rechazo
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  createdAt   DateTime  @default(now())
}

model Evaluation {
  id              String   @id @default(cuid())
  type            String   // CUSTOMER_TECH, OPS_TECH, CUSTOMER_EXEC
  otId            String
  workOrder       WorkOrder @relation(fields: [otId], references: [id])
  
  targetId        String   // ID del técnico o ejecutivo evaluado
  target          Employee @relation("EvaluationTarget", fields: [targetId], references: [id])
  
  evaluatorId     String?  // ID del supervisor (si aplica)
  evaluator       Employee? @relation("EvaluationEvaluator", fields: [evaluatorId], references: [id])
  
  // Métricas Genéricas (0-5 estrellas)
  score1          Int?     // Satisfacción / Rapidez / Experiencia Ejecutivo
  score2          Int?     // Puntualidad / Actitud Líder / Explicación Proceso
  score3          Int?     // Nivel Técnico / - / - 
  
  // Respuestas específicas
  materialUsage   String?  // MUCHO, POCO, NADA (Para Ops)
  improvements    String?  // Texto (Para Experiencia)
  comment         String?  // Comentarios generales
  
  createdAt       DateTime @default(now())

  @@unique([otId, type, targetId]) // Permite evaluar a múltiples personas en la misma OT
}

model SystemConfig {
  id    String @id @default("GLOBAL_CONFIG")
  key   String @unique
  value Json
}

// --- NUEVOS MODELOS CRM ---

model Client {
  id            String   @id @default(cuid())
  companyName   String
  rfc           String?
  contactName   String
  email         String   @unique
  phone         String?
  address       String?
  latitude      Float?
  longitude     Float?
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Vendedor propietario de la cartera
  ownerId       String?
  owner         Employee? @relation("ClientOwner", fields: [ownerId], references: [id])

  quotes        Quote[]
  deals         Deal[]
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  company       String?
  email         String
  phone         String?
  rfc           String?
  address       String?
  source        String?  // Facebook, Web, Recomendación, etc.
  stage         String   @default("PROSPECT") // PROSPECT, QUOTED, NEGOTIATION, WON, LOST
  estimatedValue Float   @default(0)
  assignedToId  String?
  assignedTo    Employee? @relation(fields: [assignedToId], references: [id])
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Quote {
  id            String   @id @default(cuid())
  quoteNumber   String   @unique // COT-2026-001
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  
  projectName   String?
  projectPhase  String?  @default("INICIAL")
  contactName   String?
  
  items         Json     // [{serial, name, code, desc, qty, price, total}]
  
  subtotal      Float    @default(0)
  tax           Float    @default(0) // IVA 16%
  adjustment    Float    @default(0) // Descuentos o cargos extra
  total         Float    @default(0)
  
  status        String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, EXPIRED
  validUntil    DateTime
  terms         String?  @default("Pago 100% anticipado. Tiempo de entrega sujeto a existencias.")
  
  pdfUrl        String?  // Link a R2
  
  creatorId     String
  creator       Employee @relation("QuoteCreator", fields: [creatorId], references: [id])
  
  sellerId      String?  // El colaborador que cerró la venta
  seller        Employee? @relation("QuoteSeller", fields: [sellerId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Deal {
  id            String   @id @default(cuid())
  title         String
  value         Float    @default(0)

  // Contacto principal
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  company       String?

  // Relación con cliente registrado (opcional)
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])

  // Vendedor asignado
  assignedToId  String?
  assignedTo    Employee? @relation("DealAssignee", fields: [assignedToId], references: [id])

  // Pipeline
  stage         String   @default("QUALIFICATION")
  probability   Int      @default(10)
  expectedClose DateTime?
  source        String?  @default("Web")

  // Notas y descripción
  description   String?
  notes         String?

  // Razón de cierre (ganado o perdido)
  closeReason   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities    DealActivity[]
}

model DealActivity {
  id         String    @id @default(cuid())
  dealId     String
  deal       Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type       String    @default("NOTE") // NOTE, CALL, EMAIL, MEETING, TASK, STAGE_CHANGE
  content    String
  authorName String?
  status     String    @default("PENDING") // PENDING, COMPLETED, FAILED
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
}

model VacationRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason      String?
  type        String   @default("ANNUAL") // ANNUAL, PERSONAL, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Candidate {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  position    String?
  stage       String   @default("APPLIED") // APPLIED, SCREENING, TECHNICAL, OFFER
  source      String?  @default("Web")
  resumeUrl   String?  // R2 Link
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id            String   @id @default(cuid())
  name          String
  category      String   // Herramienta, Vehículo, Cómputo, EPP, etc.
  serialNumber  String?  @unique
  status        String   @default("AVAILABLE") // AVAILABLE, ASSIGNED, MAINTENANCE, REPIRED
  condition     String   @default("NEW") // NEW, GOOD, FAIR, POOR
  assignedToId  String?
  assignedTo    Employee? @relation("EmployeeAssets", fields: [assignedToId], references: [id])
  assignedDate  DateTime?
  notes         String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- GESTIÓN DE CURSOS (LMS) ---
model LMSCourse {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  status      String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  isMandatory Boolean  @default(false)
  level       String   @default("BEGINNER")
  
  creatorId   String
  creator     Employee @relation("LMSCourseCreator", fields: [creatorId], references: [id])
  
  modules     LMSModule[]
  enrollments LMSEnrollment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LMSModule {
  id          String   @id @default(cuid())
  title       String
  order       Int
  courseId    String
  course      LMSCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  lessons     LMSLesson[]
}

model LMSLesson {
  id          String   @id @default(cuid())
  title       String
  type        String   // VIDEO, PDF, TEXT, QUIZ
  content     String?  // Rich text o URL (Ej: Enlace de YouTube o PDF)
  duration    Int?     // Duración estimada en minutos
  order       Int
  moduleId    String
  module      LMSModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  quiz        LMSQuiz?
  progress    LMSProgress[]
}

// --- EVALUACIONES (QUIZZES) ---
model LMSQuiz {
  id          String   @id @default(cuid())
  lessonId    String   @unique
  lesson      LMSLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  passingScore Int     @default(80)
  maxAttempts Int      @default(3)
  
  questions   LMSQuestion[]
  results     LMSQuizResult[]
}

model LMSQuestion {
  id          String   @id @default(cuid())
  quizId      String
  quiz        LMSQuiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type        String   @default("MULTIPLE_CHOICE")
  text        String
  options     Json     // [{id: 1, text: "A", isCorrect: true}, ...]
  points      Int      @default(10)
}

// --- SEGUIMIENTO DE USUARIOS ---
model LMSEnrollment {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation("LMSEnrollments", fields: [employeeId], references: [id])
  courseId    String
  course      LMSCourse @relation(fields: [courseId], references: [id])
  
  status      String   @default("ENROLLED") // ENROLLED, IN_PROGRESS, COMPLETED
  progressPct Float    @default(0)
  enrolledAt  DateTime @default(now())
  completedAt DateTime?

  @@unique([employeeId, courseId])
}

model LMSProgress {
  id          String   @id @default(cuid())
  employeeId  String
  lessonId    String
  lesson      LMSLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  status      String   @default("STARTED") // STARTED, COMPLETED
  watchTime   Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, lessonId])
}

model LMSQuizResult {
  id          String   @id @default(cuid())
  employeeId  String
  quizId      String
  quiz        LMSQuiz  @relation(fields: [quizId], references: [id])
  
  score       Float
  passed      Boolean
  attemptNum  Int      @default(1)
  answers     Json
  
  createdAt   DateTime @default(now())
}

model LMSCertificate {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation("LMSCertificates", fields: [employeeId], references: [id])
  courseName  String
  pdfUrl      String
  issueDate   DateTime @default(now())
  validationId String  @unique @default(uuid())
}


// --- GESTIÓN DE DATOS DE VENTAS (por vendedor, en BD) ---

model SalesBitacora {
  id              String   @id @default(cuid())
  sellerId        String
  seller          Employee @relation("SellerBitacora", fields: [sellerId], references: [id])
  dia             String?
  empresaVisitada String?
  nombre          String?
  potencial       Boolean  @default(false)
  decisor         Boolean  @default(false)
  resultado       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SalesDailyReport {
  id           String   @id @default(cuid())
  sellerId     String
  seller       Employee @relation("SellerReports", fields: [sellerId], references: [id])
  semana       String?
  dia          String?
  llamadas     Int      @default(0)
  efec         Int      @default(0)
  visitas      Int      @default(0)
  correos      Int      @default(0)
  mensajes     Int      @default(0)
  decisorR     Int      @default(0)
  decisorFinal Int      @default(0)
  cotizaciones Int      @default(0)
  cierres      Int      @default(0)
  venta        Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SalesPortfolio {
  id               String   @id @default(cuid())
  sellerId         String
  seller           Employee @relation("SellerPortfolio", fields: [sellerId], references: [id])
  empresa          String?
  mes              String?
  tipo             String   @default("Prospecto")
  fechaUltContacto String?
  decisor          Boolean  @default(false)
  resultado        String?
  proxContacto     String?
  motivo           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// --- PLANTILLAS OT (Catálogo de tipos de servicio para agilizar la creación de OTs) ---
model OTTemplate {
  id              String   @id @default(cuid())
  name            String   // Nombre interno de referencia
  title           String   // Título que se copia a la OT
  workDescription String   // Descripción del trabajo
  priority        String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  arrivalTime     String   @default("09:00")
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- CLIENTES OT (Catálogo operativo de sucursales/clientes para OTs) ---
model OTClient {
  id          String   @id @default(cuid())
  name        String   // Razón social / empresa
  storeNumber String?  // Número de sucursal
  storeName   String?  // Nombre de sucursal
  contact     String   // Contacto en sitio
  phone       String
  email       String?
  address     String
  otAddress   String?  // Dirección específica para OT (si difiere)
  otReference String?  // Referencias de acceso
  latitude    Float?
  longitude   Float?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
