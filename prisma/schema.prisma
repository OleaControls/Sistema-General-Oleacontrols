
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          String   @id @default(cuid())
  employeeId  String   @unique // Número de empleado
  name        String   // Nombre completo
  roles       String[] @default(["COLLABORATOR"])
  email       String   @unique
  avatar      String?
  status      String   @default("ACTIVE")
  // Note: roles (String[]) requires a GIN index via raw SQL migration for optimal performance:
  // CREATE INDEX CONCURRENTLY idx_employee_roles ON "Employee" USING GIN (roles);
  
  // 1. Datos personales básicos
  birthDate       DateTime?
  birthPlace      String?
  nationality     String?
  maritalStatus   String?
  address         String?
  phone           String?
  emergencyContactName  String?
  emergencyContactPhone String?

  // 2. Documentos oficiales (ID/Strings y Referencias PDF)
  ine             String?
  
  curp            String?
  rfc             String?
  nss             String?
  birthCertificate String? 
  proofOfResidency String?
  cv               String?
  ineDoc           String?

  // 3. Contratación
  contractSigned       String?
  privacyPolicySigned  String?
  internalRulesSigned  String?
  imssHigh            String?

  // 4. Seguimiento Laboral
  studyCertificate       String?
  degreeOrProfessionalId String?
  diplomasOrCourses      String?
  laborCertifications    String?
  recommendationLetter   String?
  performanceEvaluations String?
  receivedTraining       String?
  administrativeActs     String?
  disciplinaryReports    String?
  permitsOrLicenses      String?

  // 5. Baja del Empleado
  resignationLetter       String?
  settlementOrLiquidation String?
  imssLow                String?
  laborConstancy         String?

  // 6. Datos laborales (Actuales)
  position        String?
  department      String?
  joinDate        DateTime @default(now())
  contractType    String?  // temporal, indefinido, etc.
  workSchedule    String?  // Horario
  salary          Float?   // Salario acordado

  // 4. Datos para nómina
  bankName        String?
  bankAccount     String?  // Cuenta o CLABE
  paymentType     String?  // semanal, quincenal, mensual

  reportsTo       String?
  location        String?
  telegramChatId  String?
  techLat         Float?
  techLng         Float?
  techLastSeen    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  credentials     Credentials?

  // Vacaciones
  vacationBalance      Float    @default(0)
  vacationLastRenewal  DateTime @default(now())
  vacationRequests     VacationRequest[]

  // Relaciones Operativas

  techOTs         WorkOrder[] @relation("TechOTs")
  supervisorOTs   WorkOrder[] @relation("SupervisorOTs")
  createdOTs      WorkOrder[] @relation("CreatedOTs")
  assignedOTs     WorkOrder[] @relation("AssignedOTs")
  expenses        Expense[]

  // --- RELACIONES CRM OPUESTAS ---
  assignedLeads     Lead[]           // Leads asignados a este empleado
  assignedDeals     Deal[]           @relation("DealAssignee")
  quotesCreated     Quote[]          @relation("QuoteCreator")
  quotesSold        Quote[]          @relation("QuoteSeller")
  ownedClients      Client[]         @relation("ClientOwner")

  // --- GESTIÓN DE DATOS DE VENTAS ---
  salesBitacora     SalesBitacora[]  @relation("SellerBitacora")
  salesReports      SalesDailyReport[] @relation("SellerReports")
  salesPortfolio    SalesPortfolio[] @relation("SellerPortfolio")

// --- EVALUACIONES ---
  evaluationsReceived Evaluation[] @relation("EvaluationTarget")
  evaluationsGiven    Evaluation[] @relation("EvaluationEvaluator")

  // --- ACTIVOS Y EPP ---
  assets          Asset[]      @relation("EmployeeAssets")

  calendarEvents    CalendarEvent[]
  attendanceRecords AttendanceRecord[]
  techGoals         TechDailyGoal[]    @relation("TechGoals")
  goalsSet          TechDailyGoal[]    @relation("GoalSetBy")
  techAttendance    TechAttendanceLog[]
  panoramizaciones  OtPanoramizacion[]

  @@index([status])
  @@index([department])
}

model Credentials {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  roles      String[]
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model WorkOrder {
  id                String   @id @default(cuid())
  otNumber          String   @unique // Folio: OT-2026-001 o OT-ST01-A
  title             String
  description       String?  // Equivalent to workDescription
  status            String   @default("PENDING") // UNASSIGNED, ASSIGNED, ACCEPTED, IN_PROGRESS, COMPLETED, VALIDATED
  priority          String   @default("MEDIUM")  // LOW, MEDIUM, HIGH, URGENT
  
  // Ubicación y Establecimiento
  storeNumber       String?
  storeName         String?
  clientName        String   // mapped to 'client' in frontend
  clientEmail       String?
  clientPhone       String?
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  address           String
  secondaryAddress  String?
  otAddress         String?
  otReference       String?
  latitude          Float?
  longitude         Float?   // Changed to Float to match Leaflet mapping
  
  // Fechas y Tiempos
  scheduledDate     DateTime?
  arrivalTime       String?   // "09:00"
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Personal Relacionado
  technicianId      String?   // leadTechId
  technician        Employee? @relation("TechOTs", fields: [technicianId], references: [id])
  assistantTechs    Json?     // Almacena array de IDs o nombres de apoyo
  supportTechs      Json?
  
  supervisorId      String
  supervisor        Employee  @relation("SupervisorOTs", fields: [supervisorId], references: [id])

  creatorId         String?
  creator           Employee? @relation("CreatedOTs", fields: [creatorId], references: [id])

  assignedById      String?
  assignedBy        Employee? @relation("AssignedOTs", fields: [assignedById], references: [id])

  // Resultados, Financiero y Cierre
  assignedFunds     Float     @default(0)
  systemType        String?   // SDI, SCA, CCTV, SSA, RMC, MDE
  deliveryDetails   String?   // "Por este conducto se hace la entrega..."
  report            String?   // Resumen técnico
  pendingTasks      Json?     // Lista de observaciones/pendientes [{id, desc}]
  jornadas          Json?     // Historial de jornadas [{id, startedAt, endedAt, techId, status, pauseReason}]
  signature         String?   // Firma Técnico (Base64)
  clientSignature   String?   // Firma Cliente (Base64)
  clientSignature2  String?   // Firma Cliente 2 (Opcional)
  clientContact2    Json?     // {name, email}
  isLocked          Boolean   @default(false)
  deliveryActUrl    String?   // URL del PDF en R2
  
  evidences         Evidence[]
  expenses          Expense[]

  // --- RELACIÓN OPUESTA EVALUATION ---
  evaluations       Evaluation[]

  @@index([status])
  @@index([technicianId])
  @@index([supervisorId])
  @@index([createdAt])
  @@index([scheduledDate])
  // Índices compuestos para las queries más frecuentes del supervisor y técnico
  @@index([technicianId, status])
  @@index([supervisorId, status])
  @@index([supervisorId, createdAt])
}

model Evidence {
  id          String    @id @default(cuid())
  url         String    // Base64 o URL del archivo
  type        String    @default("IMAGE") // IMAGE, PDF
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([workOrderId])
}

model Expense {
  id          String    @id @default(cuid())
  amount      Float
  category    String
  description String?
  paymentMethod String    @default("CASH") // CASH, COMPANY_CARD, PERSONAL_CARD
  receipt     String?   // PDF/Imagen Base64
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  comment     String?   // Motivo de aprobación o rechazo
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([workOrderId])
  @@index([employeeId])
}

model Evaluation {
  id              String   @id @default(cuid())
  type            String   // CUSTOMER_TECH, OPS_TECH, CUSTOMER_EXEC
  otId            String
  workOrder       WorkOrder @relation(fields: [otId], references: [id])
  
  targetId        String   // ID del técnico o ejecutivo evaluado
  target          Employee @relation("EvaluationTarget", fields: [targetId], references: [id])
  
  evaluatorId     String?  // ID del supervisor (si aplica)
  evaluator       Employee? @relation("EvaluationEvaluator", fields: [evaluatorId], references: [id])
  
  // Métricas Genéricas (0-5 estrellas)
  score1          Int?     // Satisfacción / Rapidez / Experiencia Ejecutivo
  score2          Int?     // Puntualidad / Actitud Líder / Explicación Proceso
  score3          Int?     // Nivel Técnico / - / - 
  
  // Respuestas específicas
  materialUsage   String?  // MUCHO, POCO, NADA (Para Ops)
  improvements    String?  // Texto (Para Experiencia)
  comment         String?  // Comentarios generales
  
  createdAt       DateTime @default(now())

  @@unique([otId, type, targetId])
  @@index([targetId, createdAt])
  @@index([otId])
}

model SystemConfig {
  id    String @id @default("GLOBAL_CONFIG")
  key   String @unique
  value Json
}

// --- NUEVOS MODELOS CRM ---

model Client {
  id            String   @id @default(cuid())
  companyName   String
  rfc           String?
  contactName   String
  email         String   @unique
  phone         String?
  address       String?
  latitude      Float?
  longitude     Float?
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Vendedor propietario de la cartera
  ownerId       String?
  owner         Employee? @relation("ClientOwner", fields: [ownerId], references: [id])

  quotes        Quote[]
  deals         Deal[]

  @@index([ownerId])
  @@index([status])
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  company       String?
  email         String
  phone         String?
  rfc           String?
  address       String?
  source        String?  // Facebook, Web, Recomendación, etc.
  stage         String   @default("PROSPECT") // PROSPECT, QUOTED, NEGOTIATION, WON, LOST
  estimatedValue Float   @default(0)
  assignedToId  String?
  assignedTo    Employee? @relation(fields: [assignedToId], references: [id])
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assignedToId, createdAt])
  @@index([stage])
}

model Quote {
  id            String   @id @default(cuid())
  quoteNumber   String   @unique // COT-2026-001
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  
  projectName   String?
  projectPhase  String?  @default("INICIAL")
  contactName   String?
  
  items         Json     // [{serial, name, code, desc, qty, price, total}]
  
  subtotal      Float    @default(0)
  tax           Float    @default(0) // IVA 16%
  adjustment    Float    @default(0) // Descuentos o cargos extra
  total         Float    @default(0)
  
  status        String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, EXPIRED
  validUntil    DateTime
  terms         String?  @default("Pago 100% anticipado. Tiempo de entrega sujeto a existencias.")
  templateType  String?  @default("PRESUPUESTO") // PRESUPUESTO, PREFACTURA
  requirements  String?  @default("")             // Requerimientos del cliente
  observations  String?  @default("")             // Observaciones
  benefits      String?  @default("")             // Beneficios

  pdfUrl        String?  // Link a R2

  dealId        String?
  deal          Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  creatorId     String
  creator       Employee @relation("QuoteCreator", fields: [creatorId], references: [id])

  sellerId      String?  // El colaborador que cerró la venta
  seller        Employee? @relation("QuoteSeller", fields: [sellerId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([creatorId, createdAt])
  @@index([sellerId])
  @@index([status])
  @@index([clientId])
  @@index([dealId])
}

model QuoteRequirementPhrase {
  id        String   @id @default(cuid())
  text      String
  order     Int      @default(0)
  category  String   @default("requirements") // requirements | terms
  createdAt DateTime @default(now())
}

model Deal {
  id            String   @id @default(cuid())
  title         String
  value         Float    @default(0)

  // Contacto principal
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  company       String?

  // Relación con cliente registrado (opcional)
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])

  // Vendedor asignado
  assignedToId  String?
  assignedTo    Employee? @relation("DealAssignee", fields: [assignedToId], references: [id])

  // Pipeline
  stage         String   @default("QUALIFICATION")
  probability   Int      @default(10)
  expectedClose DateTime?
  source        String?  @default("Web")

  // Notas y descripción
  description   String?
  notes         String?

  // Razón de cierre (ganado o perdido)
  closeReason   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities    DealActivity[]
  quotes        Quote[]

  @@index([assignedToId, createdAt])
  @@index([assignedToId, stage])
  @@index([stage])
  @@index([clientId])
}

model DealActivity {
  id         String    @id @default(cuid())
  dealId     String
  deal       Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type       String    @default("NOTE") // NOTE, CALL, EMAIL, MEETING, TASK, STAGE_CHANGE
  content    String
  authorName String?
  status     String    @default("PENDING") // PENDING, COMPLETED, FAILED
  dueDate    DateTime?
  createdAt  DateTime  @default(now())

  @@index([dealId, createdAt])
}

// ── Meta diaria que el supervisor asigna al técnico ─────────────────────────
model TechDailyGoal {
  id             String   @id @default(cuid())
  date           DateTime
  techId         String
  tech           Employee @relation("TechGoals", fields: [techId], references: [id])
  clientName     String
  clientLocation String?
  notes          String?
  otNumber       String?  // Folio de la OT vinculada (ej. OT-SUCE-001)
  hasVehicle     Boolean  @default(false) // true = técnico lleva vehículo ese día
  confirmed      Boolean  @default(false) // técnico confirmó asistencia
  setById        String
  setBy          Employee @relation("GoalSetBy", fields: [setById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  attendanceLogs TechAttendanceLog[]

  @@index([techId, date])
  @@index([date])
}

// ── Registro diario de asistencia + checklists del técnico ───────────────────
model TechAttendanceLog {
  id           String         @id @default(cuid())
  date         DateTime
  techId       String
  tech         Employee       @relation(fields: [techId], references: [id])
  goalId       String?
  goal         TechDailyGoal? @relation(fields: [goalId], references: [id])

  checkInTime  String?        // "08:30"
  checkOutTime String?        // "18:00"

  // Checklist 1 — Equipo personal (JSON)
  // { uniform, epp, toolsBasic, toolsSpecial, materials } → true/false/null
  checklistPersonal Json?
  personalMissing   String?    // descripción de faltantes
  personalReportSent Boolean  @default(false)

  // Checklist 2 — Vehículo (JSON)
  // { fuel, cleanInterior, cleanExterior, odometer, functionality } → true/false/null
  checklistVehicle  Json?
  vehicleMissing    String?    // descripción de faltantes
  vehicleReportSent Boolean   @default(false)

  step    String  @default("CHECKIN") // CHECKIN | PERSONAL | VEHICLE | DONE
  status  String  @default("PENDING") // PENDING | COMPLETE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([techId, date])
  @@index([techId])
  @@index([date])
}

model AttendanceRecord {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  date         DateTime
  type         String   // PRESENT, ABSENT, LATE, PERMISSION, MEDICAL, HOLIDAY
  checkIn      String?  // "09:00"
  checkOut     String?  // "18:00"
  minutesLate  Int?
  notes        String?
  registeredBy String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([date])
}

model VacationRequest {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason      String?
  type        String   @default("ANNUAL") // ANNUAL, PERSONAL, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
}

model Candidate {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  position    String?
  stage       String   @default("APPLIED") // APPLIED, SCREENING, TECHNICAL, OFFER
  source      String?  @default("Web")
  resumeUrl   String?  // R2 Link
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id            String   @id @default(cuid())
  name          String
  category      String   // Herramienta, Vehículo, Cómputo, EPP, etc.
  serialNumber  String?  @unique
  status        String   @default("AVAILABLE") // AVAILABLE, ASSIGNED, MAINTENANCE, REPIRED
  condition        String   @default("NEW") // NEW, GOOD, FAIR, POOR
  conditionPercent Int      @default(100)   // 0-100 estado de la herramienta
  assignedToId  String?
  assignedTo    Employee? @relation("EmployeeAssets", fields: [assignedToId], references: [id])
  assignedDate  DateTime?
  notes         String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([assignedToId])
}

// --- GESTIÓN DE DATOS DE VENTAS (por vendedor, en BD) ---

model SalesBitacora {
  id              String   @id @default(cuid())
  sellerId        String
  seller          Employee @relation("SellerBitacora", fields: [sellerId], references: [id])
  dia             String?
  empresaVisitada String?
  nombre          String?
  potencial       Boolean  @default(false)
  decisor         Boolean  @default(false)
  resultado       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sellerId, createdAt])
}

model SalesDailyReport {
  id           String   @id @default(cuid())
  sellerId     String
  seller       Employee @relation("SellerReports", fields: [sellerId], references: [id])
  semana       String?
  dia          String?
  llamadas     Int      @default(0)
  efec         Int      @default(0)
  visitas      Int      @default(0)
  correos      Int      @default(0)
  mensajes     Int      @default(0)
  decisorR     Int      @default(0)
  decisorFinal Int      @default(0)
  cotizaciones Int      @default(0)
  cierres      Int      @default(0)
  venta        Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sellerId])
}

model SalesPortfolio {
  id               String   @id @default(cuid())
  sellerId         String
  seller           Employee @relation("SellerPortfolio", fields: [sellerId], references: [id])
  empresa          String?
  mes              String?
  tipo             String   @default("Prospecto")
  fechaUltContacto String?
  decisor          Boolean  @default(false)
  resultado        String?
  proxContacto     String?
  motivo           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sellerId])
}

// --- CATÁLOGO DE PRODUCTOS (base para cotizaciones) ---
model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  brand       String?
  category    String?
  subcategory String?
  description String?
  unit        String   @default("PZA") // PZA, KIT, MTS, JGO, SRV
  price       Float    @default(0)
  currency    String   @default("MXN") // MXN, USD
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- PLANTILLAS OT (Catálogo de tipos de servicio para agilizar la creación de OTs) ---
model OTTemplate {
  id              String   @id @default(cuid())
  name            String   // Nombre interno de referencia
  title           String   // Título que se copia a la OT
  workDescription String   // Descripción del trabajo
  priority        String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  arrivalTime     String   @default("09:00")
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- CLIENTES OT (Catálogo operativo de sucursales/clientes para OTs) ---
model OTClient {
  id          String   @id @default(cuid())
  name        String   // Razón social / empresa
  storeNumber String?  // Número de sucursal
  storeName   String?  // Nombre de sucursal
  contact     String   // Contacto en sitio
  phone       String
  email       String?
  address     String
  otAddress   String?  // Dirección específica para OT (si difiere)
  otReference String?  // Referencias de acceso
  latitude    Float?
  longitude   Float?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  
  portalToken    String? @unique
  calendarEvents CalendarEvent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- AUDITORÍA PERSONAL DIARIA ---
model PersonalAudit {
  id          String   @id @default(cuid())
  employeeId  String
  projectName String
  auditDate   DateTime
  isLeader    Boolean  @default(false)
  actionArea  String
  didWell     Json
  didPoor     Json
  improvements Json
  createdAt   DateTime @default(now())

  @@index([employeeId])
}

// ── PROP del técnico — Prioridades · Realidades · Opciones · Plan ────────────
// Marco de planeación personal; cada categoría guarda 3 opciones (array de texto).
model TechnicianProp {
  id           String   @id @default(cuid())
  employeeId   String
  employeeName String              // Denormalizado para listarlo en Operaciones
  objetivo     String   @default("") // Enfoque / situación que aborda el PROP (opcional)
  prioridades  Json                 // string[] — 3 opciones
  realidades   Json                 // string[] — 3 opciones
  opciones     Json                 // string[] — 3 opciones
  plan         Json                 // string[] — 3 opciones
  createdAt    DateTime @default(now())

  @@index([employeeId])
  @@index([createdAt])
}

// ── Panoramización de sitio — una por OT ────────────────────────────────────
model OtPanoramizacion {
  id               String   @id @default(cuid())
  otNumber         String   @unique   // Una sola panoramización por OT
  techId           String
  tech             Employee @relation(fields: [techId], references: [id])
  goalId           String?

  condicionesSitio String   // Estado físico del área al llegar
  planEjecucion    String   // Estrategia, ruta o método de instalación
  requerimientos   String   // Materiales, herramientas, equipo de apoyo
  bloqueos         String?  // Legado — reemplazado por obstaculos + algoritmos
  obstaculos       String   @default("") // Obstáculos o bloqueos encontrados
  algoritmos       String   @default("") // Pasos o algoritmo para resolverlos

  createdAt        DateTime @default(now())

  @@index([techId])
  @@index([createdAt])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("VISIT") // VISIT, MAINTENANCE, OTHER
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)
  color       String   @default("#3b82f6")

  otClientId  String?
  otClient    OTClient? @relation(fields: [otClientId], references: [id])

  userId      String
  user        Employee  @relation(fields: [userId], references: [id])

  evidences   Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, startDate])
  @@index([otClientId])
}

// ── Comunicados / Anuncios ───────────────────────────────────────────────────
model Announcement {
  id                   String   @id @default(cuid())
  title                String
  content              String
  type                 String   @default("INFO")   // INFO, URGENT, POLICY
  category             String   @default("GENERAL") // GENERAL, TECNICO, VENTAS, ADMIN, RRHH
  targetDepts          String[] @default([])        // [] = todos
  targetRoles          String[] @default([])        // [] = todos
  requiresConfirmation Boolean  @default(false)
  authorId             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  reads                AnnouncementRead[]

  @@index([createdAt])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  employeeId     String
  confirmedAt    DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, employeeId])
  @@index([announcementId])
  @@index([employeeId])
}

// ── Encuestas de Clima ───────────────────────────────────────────────────────
model Survey {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      String           @default("ACTIVE") // DRAFT, ACTIVE, CLOSED
  anonymous   Boolean          @default(true)
  endDate     DateTime?
  questions   Json             @default("[]")
  targetDepts String[]         @default([])
  targetRoles String[]         @default([])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  responses   SurveyResponse[]

  @@index([status, createdAt])
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  employeeId  String?
  answers     Json     @default("{}")
  submittedAt DateTime @default(now())
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, employeeId])
  @@index([surveyId])
}

// ── Nómina ────────────────────────────────────────────────────────────────────
model PayrollPeriod {
  id              String        @id @default(cuid())
  name            String        // "1ª Quincena Enero 2026"
  type            String        @default("QUINCENAL") // SEMANAL, QUINCENAL, MENSUAL
  startDate       DateTime
  endDate         DateTime
  status          String        @default("DRAFT")    // DRAFT, APPROVED, PAID
  totalGross      Float         @default(0)
  totalDeductions Float         @default(0)
  totalNet        Float         @default(0)
  employeeCount   Int           @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           PayrollItem[]

  @@index([status, startDate])
}

model PayrollItem {
  id              String        @id @default(cuid())
  periodId        String
  period          PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employeeId      String
  employeeName    String
  employeePos     String?
  employeeDept    String?
  baseSalary      Float         @default(0)
  absenceDays     Int           @default(0)
  absenceDeduct   Float         @default(0)
  overtimeHours   Float         @default(0)
  overtimePay     Float         @default(0)
  bonuses         Json          @default("[]")       // [{concept, amount}]
  bonusTotal      Float         @default(0)
  grossPay        Float         @default(0)
  imss            Float         @default(0)
  isr             Float         @default(0)
  infonavit       Float         @default(0)
  extraDeductions Json          @default("[]")       // [{concept, amount}]
  totalDeductions Float         @default(0)
  netPay          Float         @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([periodId, employeeId])
  @@index([periodId])
  @@index([employeeId])
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO DE GESTIÓN DE PROYECTOS (rol PROJECT_MANAGER)
// Las referencias a empleados se guardan como String (id) + snapshot de nombre,
// siguiendo el patrón de PersonalAudit/Announcement, para no acoplar el modelo
// Employee. Cada área del acta de proyecto tiene su propio modelo hijo.
// ═══════════════════════════════════════════════════════════════════════════

model Project {
  id            String   @id @default(cuid())
  code          String   @unique          // PROY-2026-001
  name          String

  // Acta de inicio
  objective     String?                    // Objetivo
  scope         String?                    // Alcance
  justification String?                    // Justificación
  sponsor       String?                    // Patrocinador
  managerId     String?                    // Responsable del proyecto (Employee.id)
  managerName   String?
  clientName    String?

  // Estado y avance
  status        String   @default("INICIO") // INICIO, PLANEACION, EJECUCION, CIERRE, CERRADO
  progress      Int      @default(0)         // % avance (0-100)

  // Tiempo
  startDate     DateTime?
  endDate       DateTime?

  // Costos
  budget        Float    @default(0)         // Presupuesto autorizado
  actualCost    Float    @default(0)         // Gasto real acumulado (snapshot)

  // Alcance
  requirements  String?                      // Requerimientos
  deliverables  String?                      // Entregables

  // Cierre
  lessonsLearned String?                     // Lecciones aprendidas
  closureNotes   String?                     // Notas de cierre
  closureActUrl  String?                     // PDF acta de cierre (R2)
  closedAt       DateTime?

  // Integración y automatización
  autoProgress   Boolean  @default(false)    // avance calculado desde tareas
  linkedOtIds    Json?                        // IDs de OTs vinculadas
  linkedQuoteIds Json?                        // IDs de cotizaciones vinculadas

  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks          ProjectTask[]
  risks          ProjectRisk[]
  costs          ProjectCost[]
  resources      ProjectResource[]
  qualityItems   ProjectQuality[]
  communications ProjectCommunication[]
  incidents      ProjectIncident[]
  documents      ProjectDocument[]
  changes        ProjectChange[]
  activities     ProjectActivity[]

  @@index([status])
  @@index([managerId])
  @@index([archived])
}

// Bitácora de actividad / auditoría del proyecto
model ProjectActivity {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action     String                           // "Creó tarea", "Cambió estado a EJECUCION", etc.
  detail     String?
  authorName String?
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}

// Cronograma / Actividades / Hitos / Tiempo / Dependencias
model ProjectTask {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  type            String   @default("TASK")    // TASK, MILESTONE
  status          String   @default("PENDING") // PENDING, IN_PROGRESS, DONE, BLOCKED
  progress        Int      @default(0)          // % avance
  startDate       DateTime?
  endDate         DateTime?
  dependsOn       Json?                          // IDs de tareas predecesoras
  responsibleId   String?
  responsibleName String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
}

// Gestión de riesgos
model ProjectRisk {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description   String
  probability   String   @default("MEDIA")   // BAJA, MEDIA, ALTA
  impact        String   @default("MEDIO")   // BAJO, MEDIO, ALTO
  mitigation    String?
  ownerId       String?
  ownerName     String?
  status        String   @default("ABIERTO") // ABIERTO, MITIGADO, CERRADO, MATERIALIZADO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// Gestión de costos (presupuesto vs real → variación/pronóstico calculado)
model ProjectCost {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  concept       String
  category      String   @default("GENERAL") // MATERIAL, MANO_OBRA, EQUIPO, OTRO
  budgeted      Float    @default(0)
  actual        Float    @default(0)
  date          DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// Gestión de recursos (personal, equipos, materiales)
model ProjectResource {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type           String   @default("PERSONAL") // PERSONAL, EQUIPO, MATERIAL
  name           String
  quantity       Float    @default(1)
  unit           String?
  cost           Float    @default(0)
  responsibility String?                        // Asignación de responsabilidades
  assignedToId   String?
  assignedName   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

// Gestión de la calidad (criterios, inspecciones, pruebas, indicadores)
model ProjectQuality {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          String   @default("CRITERIO")  // CRITERIO, INSPECCION, PRUEBA, INDICADOR
  description   String
  target        String?                          // Criterio de aceptación / valor esperado
  result        String?                          // Resultado obtenido
  status        String   @default("PENDIENTE")  // PENDIENTE, APROBADO, RECHAZADO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// Gestión de comunicaciones (minutas, reportes, reuniones)
model ProjectCommunication {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          String   @default("MINUTA")     // MINUTA, REPORTE, REUNION
  title         String
  content       String?
  channel       String?                          // Canal de comunicación
  date          DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// Gestión de incidencias
model ProjectIncident {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  priority        String   @default("MEDIA")    // BAJA, MEDIA, ALTA, CRITICA
  responsibleId   String?
  responsibleName String?
  status          String   @default("ABIERTA")  // ABIERTA, EN_PROCESO, RESUELTA
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
}

// Gestión documental (planos, manuales, contratos, evidencias, versionado)
model ProjectDocument {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  category      String   @default("OTRO")       // PLANO, MANUAL, CONTRATO, EVIDENCIA, OTRO
  url           String
  version       String   @default("1.0")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// Control de cambios (solicitudes, impacto, aprobaciones, historial)
model ProjectChange {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  impact          String?                         // Evaluación del impacto
  status          String   @default("SOLICITADO") // SOLICITADO, APROBADO, RECHAZADO
  requestedById   String?
  requestedByName String?
  decidedById     String?
  decidedByName   String?
  decidedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
}
